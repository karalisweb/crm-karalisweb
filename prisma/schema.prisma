// Schema Prisma per Sales Support App
// CRM per agenzia di web marketing

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// LEAD - Dati da Google Maps + Audit + CRM
// ==========================================
model Lead {
  id        String   @id @default(uuid())

  // Dati da Google Maps (Apify)
  name              String
  address           String?
  phone             String?
  phoneVerified     Boolean   @default(false) @map("phone_verified") // Numero verificato manualmente
  whatsappNumber    String?   @map("whatsapp_number")
  whatsappSource    String?   @map("whatsapp_source") // "website" | "google_maps" | "manual" | "none"
  website           String?
  socialUrl         String?   @map("social_url")
  category          String?
  segment           String?                          // Micro-segmento: "infissi", "edilizia", "immobiliare", etc.
  googleRating      Decimal?  @map("google_rating") @db.Decimal(2, 1)
  googleReviewsCount Int?     @map("google_reviews_count")
  googleMapsUrl     String?   @map("google_maps_url")
  placeId           String?   @unique @map("place_id")

  // Risultato Audit
  auditStatus       AuditStatus @default(PENDING) @map("audit_status")
  auditCompletedAt  DateTime?   @map("audit_completed_at")
  opportunityScore  Int?        @map("opportunity_score")

  // Audit details (JSON per flessibilita)
  auditData         Json?       @map("audit_data")

  // Talking points generati
  talkingPoints     String[]    @map("talking_points")

  // ==========================================
  // SEGNALI COMMERCIALI (Sistema 5 chiamate/giorno)
  // ==========================================
  // Tag commerciale obbligatorio (1 solo per lead)
  commercialTag     CommercialTag?  @map("commercial_tag")
  commercialTagReason String?       @map("commercial_tag_reason")

  // I 5 segnali commerciali (JSON)
  commercialSignals Json?           @map("commercial_signals")
  /*
    {
      "adsEvidence": "strong" | "medium" | "weak" | "none",
      "adsEvidenceReason": "...",
      "trackingPresent": true | false,
      "consentModeV2": "yes" | "no" | "uncertain",
      "ctaClear": true | false,
      "offerFocused": true | false,
      "analyzedAt": "ISO date",
      "errors": ["..."] // opzionale
    }
  */

  // Priorita commerciale (1=alta, 4=skip)
  commercialPriority Int?           @map("commercial_priority")

  // Flag per dashboard "Chiamabili oggi"
  isCallable        Boolean         @default(false) @map("is_callable")

  // CRM Pipeline
  pipelineStage     PipelineStage @default(DA_ANALIZZARE) @map("pipeline_stage")
  outreachChannel   String?       @map("outreach_channel") // "WA" | "EMAIL"
  channelHistory    Json?         @map("channel_history") // [{channel, setAt, reason}]
  email             String?       // Email del prospect (per fallback invio)
  outreachMailSent  Json?         @map("outreach_mail_sent") // {subject, body, hook, generatedAt} — cosa ha ricevuto davvero (per registrare il video coerente)
  optInSentAt       DateTime?     @map("opt_in_sent_at")       // T1: prima mail (dedup + tempistica follow-up)
  optInFollowupAt   DateTime?     @map("opt_in_followup_at")   // T2: primo follow-up
  optInFollowup2At  DateTime?     @map("opt_in_followup2_at")  // T3: secondo follow-up
  coldCallTaskAt    DateTime?     @map("cold_call_task_at")    // T4: task telefonata creato (solo lead caldi/HOT)
  coldBreakupAt     DateTime?     @map("cold_breakup_at")      // T5: break-up inviato → NURTURING

  // Questionario / self-assessment (segnale di calore → CALDO_REATTIVO)
  questionnaireCompletedAt DateTime? @map("questionnaire_completed_at")
  questionnaireResponses   Json?     @map("questionnaire_responses")
  questionnaireScore       Int?      @map("questionnaire_score") // punteggio self-assessment (smistamento per fascia)

  // Bozza mail 1 pre-generata in attesa di approvazione ({subject, body, hook, generatedAt})
  outreachDraft     Json?         @map("outreach_draft")
  lostReason        LostReason?   @map("lost_reason")
  lostReasonNotes   String?       @map("lost_reason_notes")

  // Contatore tentativi chiamata (per fase vendita)
  callAttempts      Int           @default(0) @map("call_attempts")

  // Data/ora appuntamento (per CALL_FISSATA)
  appointmentAt     DateTime?     @map("appointment_at")

  // Data invio proposta (per tracking)
  offerSentAt       DateTime?     @map("offer_sent_at")

  // ==========================================
  // 2-PROMPT CHAIN (Analista + Sceneggiatore)
  // ==========================================
  analystOutput         Json?       @map("analyst_output")
  analystApprovedAt     DateTime?   @map("analyst_approved_at")
  analystApprovedBy     String?     @map("analyst_approved_by")
  scriptApprovedAt      DateTime?   @map("script_approved_at")
  scriptApprovedBy      String?     @map("script_approved_by")
  puntoDoloreBreve      String?     @map("punto_dolore_breve") @db.Text
  puntoDoloreLungo      String?     @map("punto_dolore_lungo") @db.Text

  // ==========================================
  // VIDEO OUTREACH
  // ==========================================
  // Script video generato dall'app
  videoScriptData   Json?         @map("video_script_data")
  // Tracking invio video
  videoSentAt       DateTime?     @map("video_sent_at")
  videoViewedAt     DateTime?     @map("video_viewed_at")

  // ==========================================
  // GEMINI AI ANALYSIS
  // ==========================================
  geminiAnalysis    Json?         @map("gemini_analysis")
  geminiAnalyzedAt  DateTime?     @map("gemini_analyzed_at")

  // Score breakdown (dettaglio punteggio per categoria)
  scoreBreakdown    Json?         @map("score_breakdown")

  // Override manuale del tier settore ("high_ticket" | "standard" | "low_ticket")
  tierOverride      String?       @map("tier_override")

  // ==========================================
  // ADS — Solo verifica manuale
  // ==========================================
  hasActiveGoogleAds    Boolean     @default(false) @map("has_active_google_ads")
  hasActiveMetaAds      Boolean     @default(false) @map("has_active_meta_ads")
  adsVerifiedManually   Boolean     @default(false) @map("ads_verified_manually")
  googleAdsCopy         String?     @map("google_ads_copy")
  metaAdsCopy           String?     @map("meta_ads_copy")
  landingPageUrl        String?     @map("landing_page_url")
  landingPageText       String?     @map("landing_page_text") @db.Text
  adsCheckedAt          DateTime?   @map("ads_checked_at")
  adsCoherenceWarning   String?     @map("ads_coherence_warning")
  emailCheckedAt        DateTime?   @map("email_checked_at") // ultimo tentativo di trovare l'email (cooldown recover-emails)

  // ==========================================
  // VIDEO / SCRIPT TELLA
  // ==========================================
  scriptRegeneratedAt DateTime?   @map("script_regenerated_at")
  videoViewsCount     Int         @default(0) @map("video_views_count")
  videoTrackingToken  String?     @unique @map("video_tracking_token")
  videoYoutubeUrl     String?     @map("video_youtube_url")
  videoYoutubeId      String?     @map("video_youtube_id")
  videoTellaUrl       String?     @map("video_tella_url")
  videoLandingUrl     String?     @map("video_landing_url")
  videoLandingSlug    String?     @map("video_landing_slug")
  videoWpPostId       Int?        @map("video_wp_post_id")  // ID del post WordPress per update/delete
  landingPuntoDolore  String?     @map("landing_punto_dolore") @db.Text

  // YouTube player tracking (eventi dalla landing page)
  videoFirstPlayAt    DateTime?   @map("video_first_play_at")
  videoMaxWatchPercent Int?       @map("video_max_watch_percent")
  videoCompletedAt    DateTime?   @map("video_completed_at")

  // ==========================================
  // FOLLOW-UP TRACKING
  // ==========================================
  letterSentAt      DateTime?     @map("letter_sent_at")
  linkedinSentAt    DateTime?     @map("linkedin_sent_at")

  // ==========================================
  // RISPOSTA PROSPECT
  // ==========================================
  respondedAt       DateTime?     @map("responded_at")
  respondedVia      String?       @map("responded_via") // "email" | "phone" | "linkedin" | "whatsapp"

  // ==========================================
  // QUALIFICAZIONE (Daniela)
  // ==========================================
  danielaNotes      String?       @map("daniela_notes")
  qualifiedAt       DateTime?     @map("qualified_at")
  qualifiedBy       String?       @map("qualified_by")

  // Verifica audit (checklist di Daniela)
  auditVerified           Boolean   @default(false) @map("audit_verified")
  auditVerifiedAt         DateTime? @map("audit_verified_at")
  auditVerifiedBy         String?   @map("audit_verified_by")
  auditVerificationChecks Json?     @map("audit_verification_checks")

  // ==========================================
  // QUALIFICA AUTOMATICA PROSPECT
  // ==========================================
  // Punteggio qualifica (0-100) — scoring basato su sito + ads attive
  qualificationScore    Int?        @map("qualification_score")
  // Priorita derivata: "ALTA" / "MEDIA" / "BASSA"
  qualificationPriority String?     @map("qualification_priority")
  // Angolo pre-compilato per video Loom
  angoloLoom            String?     @map("angolo_loom")

  // Dati Google Ads (da DataForSEO)
  googleAdsActive       Boolean?    @map("google_ads_active")
  googleAdsCount        Int?        @map("google_ads_count")

  // Dati Meta Ads (da Meta Ad Library)
  metaAdsActive         Boolean?    @map("meta_ads_active")
  metaAdsCount          Int?        @map("meta_ads_count")
  metaPageName          String?     @map("meta_page_name")

  // Flag titolare verificato (Daniela)
  titolareVerificato    Boolean     @default(false) @map("titolare_verificato")

  // Output completo qualifica (JSON)
  qualificationData     Json?       @map("qualification_data")
  // Errori non bloccanti durante qualifica
  qualificationErrors   String[]    @map("qualification_errors")
  // Timestamp qualifica automatica
  qualificationAt       DateTime?   @map("qualification_at")

  // ==========================================
  // UNSUBSCRIBE (GDPR)
  // ==========================================
  unsubscribed      Boolean       @default(false)
  unsubscribedAt    DateTime?     @map("unsubscribed_at")

  // ==========================================
  // RECONTACT (Da richiamare tra 6 mesi)
  // ==========================================
  recontactAt       DateTime?     @map("recontact_at")

  // ==========================================
  // RETE BNI (referenze / interesse membri)
  // ==========================================
  // "referral" = persona presentata da un membro | "member_interest" = il membro stesso e' interessato
  bniOriginType     String?       @map("bni_origin_type")
  referralNeed      String?       @map("referral_need")    // Di cosa ha bisogno il referito / servizio d'interesse

  // ==========================================
  // CRM MINIMALE per logging chiamate
  // ==========================================
  // Ultimo esito chiamata
  lastCallOutcome   CallOutcome?  @map("last_call_outcome")
  lastCallNotes     String?       @map("last_call_notes")

  // Obiezione principale (per tracking pattern)
  mainObjection     Objection?    @map("main_objection")
  objectionNotes    String?       @map("objection_notes")

  // Next step (pianificazione follow-up)
  nextStepType      NextStepType? @map("next_step_type")
  nextStepNotes     String?       @map("next_step_notes")

  // Activity tracking
  lastContactedAt   DateTime?   @map("last_contacted_at")
  nextFollowupAt    DateTime?   @map("next_followup_at")
  assignedTo        String?     @map("assigned_to")

  // Metadata
  source            String      @default("google_maps")
  notes             String?
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  // Relazioni
  searchId          String?     @map("search_id")
  search            Search?     @relation(fields: [searchId], references: [id])
  activities          Activity[]
  tasks               Task[]

  // Relazioni BNI
  referredByMembroId String?    @map("referred_by_membro_id")
  referredByMembro   BniMembro? @relation("BniReferral", fields: [referredByMembroId], references: [id])
  oneToOneId         String?    @map("one_to_one_id")
  oneToOne           OneToOne?  @relation("OneToOneLeads", fields: [oneToOneId], references: [id])

  @@index([opportunityScore(sort: Desc)], name: "idx_leads_score")
  @@index([pipelineStage], name: "idx_leads_stage")
  @@index([auditStatus], name: "idx_leads_audit_status")
  // Indici per sistema commerciale
  @@index([commercialTag], name: "idx_leads_commercial_tag")
  @@index([commercialPriority], name: "idx_leads_commercial_priority")
  @@index([isCallable], name: "idx_leads_callable")
  // Indici per pipeline
  @@index([appointmentAt], name: "idx_leads_appointment")
  @@index([offerSentAt], name: "idx_leads_offer_sent")
  @@index([nextFollowupAt], name: "idx_leads_followup")
  // Indici per outreach e qualificazione
  @@index([recontactAt], name: "idx_leads_recontact")
  @@index([videoSentAt], name: "idx_leads_video_sent")
  @@index([qualifiedAt], name: "idx_leads_qualified")
  @@index([letterSentAt], name: "idx_leads_letter_sent")
  @@index([linkedinSentAt], name: "idx_leads_linkedin_sent")
  // Indici per qualifica automatica
  @@index([qualificationScore(sort: Desc)], name: "idx_leads_qualification_score")
  @@index([qualificationPriority], name: "idx_leads_qualification_priority")
  @@index([segment], name: "idx_leads_segment")
  // Indici per rete BNI
  @@index([source], name: "idx_leads_source")
  @@index([referredByMembroId], name: "idx_leads_referred_by")
  @@index([oneToOneId], name: "idx_leads_one_to_one")
  @@map("leads")
}

// ==========================================
// ACTIVITY - Storico attivita sul lead
// ==========================================
model Activity {
  id        String   @id @default(uuid())

  type      ActivityType
  outcome   CallOutcome?
  notes     String?
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  // Relazione
  leadId    String   @map("lead_id")
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId], name: "idx_activities_lead")
  @@map("activities")
}

// ==========================================
// SEARCH - Ricerche salvate
// ==========================================
model Search {
  id              String       @id @default(uuid())

  query           String       // es. "Ristoranti"
  location        String       // es. "Milano centro"
  apifyRunId      String?      @map("apify_run_id")
  status          SearchStatus @default(PENDING)
  leadsFound      Int          @default(0) @map("leads_found")
  leadsWithWebsite Int         @default(0) @map("leads_with_website")
  errorMessage    String?      @map("error_message")
  sortOrder       Int?         @map("sort_order") // Ordine manuale drag & drop
  createdAt       DateTime     @default(now()) @map("created_at")
  completedAt     DateTime?    @map("completed_at")

  // Relazione
  leads           Lead[]

  @@index([sortOrder], name: "idx_searches_sort_order")
  @@map("searches")
}

// ==========================================
// TASK - Reminder e follow-up
// ==========================================
model Task {
  id          String    @id @default(uuid())

  title       String
  description String?
  dueAt       DateTime? @map("due_at")
  completedAt DateTime? @map("completed_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  // Relazione
  leadId      String    @map("lead_id")
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([dueAt], name: "idx_tasks_due")
  @@map("tasks")
}

// ==========================================
// USER - Per autenticazione
// ==========================================
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String    // Hash bcrypt
  name          String?
  role          UserRole  @default(USER)
  twoFactorEnabled Boolean @default(false) @map("two_factor_enabled")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relazioni
  otpCodes      OtpCode[]
  passwordResets PasswordReset[]

  @@map("users")
}

// ==========================================
// OTP CODE - Codici per autenticazione 2FA
// ==========================================
model OtpCode {
  id        String   @id @default(uuid())
  code      String   // Codice OTP a 6 cifre (hashed)
  email     String   // Email destinatario
  type      OtpType  @default(TWO_FACTOR) // Tipo di OTP
  expiresAt DateTime @map("expires_at") // Scadenza (10 minuti)
  used      Boolean  @default(false) // Se già utilizzato
  attempts  Int      @default(0) // Tentativi di verifica
  createdAt DateTime @default(now()) @map("created_at")

  // Relazione con utente
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email, type], name: "idx_otp_email_type")
  @@index([expiresAt], name: "idx_otp_expires")
  @@map("otp_codes")
}

// ==========================================
// PASSWORD RESET - Token per recupero password
// ==========================================
model PasswordReset {
  id        String   @id @default(uuid())
  token     String   @unique // Token univoco (hashed)
  email     String   // Email utente
  expiresAt DateTime @map("expires_at") // Scadenza (1 ora)
  used      Boolean  @default(false) // Se già utilizzato
  createdAt DateTime @default(now()) @map("created_at")

  // Relazione con utente
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email], name: "idx_password_reset_email")
  @@index([expiresAt], name: "idx_password_reset_expires")
  @@map("password_resets")
}

// ==========================================
// RETE BNI - Membri dei capitoli
// ==========================================
// Un membro BNI ha doppia natura: possibile cliente diretto E fonte di referenze.
// Le opportunita' (interesse del membro o referenze ricevute) diventano Lead
// con source="bni", collegati qui via Lead.referredByMembroId / Lead.oneToOneId.
model BniMembro {
  id          String   @id @default(uuid())

  name        String                                  // Nome e cognome
  profession  String?                                 // Professione / categoria BNI
  company     String?                                 // Azienda
  chapter     String?                                 // Capitolo BNI (campo libero, autocompletato)
  phone       String?
  email       String?
  website     String?
  notes       String?  @db.Text

  status      BniMemberStatus @default(ATTIVO)
  knownSince  DateTime?        @map("known_since")     // Membro / conosciuto dal

  // Denormalizzati per dashboard veloce (aggiornati a ogni 121)
  oneToOneCount  Int       @default(0) @map("one_to_one_count")
  lastOneToOneAt DateTime? @map("last_one_to_one_at")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relazioni
  oneToOnes     OneToOne[]
  referredLeads Lead[]     @relation("BniReferral")

  @@index([chapter], name: "idx_bni_membro_chapter")
  @@index([lastOneToOneAt], name: "idx_bni_membro_last121")
  @@map("bni_membri")
}

// ==========================================
// 121 - Incontro uno-a-uno con un membro BNI
// ==========================================
// L'evento centrale: salvarlo genera 0..N Lead (interesse del membro + referenze).
model OneToOne {
  id        String   @id @default(uuid())

  membroId  String    @map("membro_id")
  membro    BniMembro @relation(fields: [membroId], references: [id], onDelete: Cascade)

  date      DateTime                                  // Data del 121
  location  String?                                   // Dove (caffe', ufficio, online)
  notes     String?  @db.Text                         // Cosa fa / cosa cerca / come aiutarlo

  // Esito 1: interesse diretto del membro per i miei servizi
  memberInterested Boolean @default(false) @map("member_interested")
  interestService  String? @map("interest_service")   // SEO / Ads / Sito / ...

  // Esito 2: referenze ricevute (i Lead generati sono collegati via Lead.oneToOneId)
  referralsCount   Int     @default(0) @map("referrals_count")

  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  // Lead generati da questo 121 (referenze + eventuale interesse del membro)
  generatedLeads Lead[] @relation("OneToOneLeads")

  @@index([membroId], name: "idx_121_membro")
  @@index([date], name: "idx_121_date")
  @@map("one_to_ones")
}

enum BniMemberStatus {
  ATTIVO      // Membro attivo del capitolo
  VISITATORE  // Ospite / visitatore (non membro)
  EX_MEMBRO   // Uscito dal capitolo
}

// ==========================================
// ENUMS
// ==========================================

enum AuditStatus {
  PENDING     // In attesa
  RUNNING     // In analisi
  COMPLETED   // Completato
  FAILED      // Errore
  NO_WEBSITE  // Nessun sito web
  TIMEOUT     // Timeout
}

// ==========================================
// PIPELINE COMMERCIALE
// ==========================================
enum PipelineStage {
  // === ANALISI ===
  DA_ANALIZZARE       // Importato, serve analisi Gemini
  HOT_LEAD            // Score ≥80, analizzato
  WARM_LEAD           // Score 50-79, analizzato
  COLD_LEAD           // Score <50, basso potenziale

  // === RETE BNI ===
  BNI_DA_LAVORARE     // Opportunita' da BNI (referenza o interesse membro) da lavorare

  // === SEGNALE DI CALORE (questionario compilato / risposta / interesse) ===
  CALDO_REATTIVO      // Ha dato un segnale → esce dalla sequenza fredda, va al video
  NURTURING           // Non reattivo a fine sequenza: stop solleciti, tocchi lenti e radi

  // === VIDEO ===
  FARE_VIDEO          // Video da registrare
  VIDEO_INVIATO       // Video inviato (WA o Email)

  // === FOLLOW-UP (3 round, stesso canale) ===
  FOLLOW_UP_1         // Primo follow-up
  FOLLOW_UP_2         // Secondo follow-up
  FOLLOW_UP_3         // Terzo follow-up

  // === LINKEDIN ===
  LINKEDIN            // Outreach LinkedIn

  // === TELEFONATE (solo canale email, 3 round) ===
  TELEFONATA_1        // Prima telefonata
  TELEFONATA_2        // Seconda telefonata
  TELEFONATA_3        // Terza telefonata

  // === VENDITA ===
  CALL_FISSATA        // Call conoscitiva fissata
  IN_TRATTATIVA       // Trattativa in corso

  // === CHIUSURA ===
  CLIENTE             // Vinto
  PERSO               // Perso

  // === ARCHIVIO ===
  ARCHIVIATO          // Archivio generico
  NON_TARGET          // Non in target (auto)
  SENZA_SITO          // Nessun sito web (auto)
}

// Motivi per cui un lead e' stato perso
enum LostReason {
  NO_INTERESSE    // Non gli interessa (in chiamata)
  NO_BUDGET       // Non ha budget
  GHOST_CALL      // Non si presenta e sparisce
  GHOST_OFFERTA   // Non paga dopo 20gg
  COMPETITOR      // Ha scelto un competitor
  TEMPISTICA      // Non e' il momento giusto
  ALTRO           // Altro (specificare in notes)
}

enum ActivityType {
  CALL              // Chiamata
  NOTE              // Nota
  EMAIL_SENT        // Email inviata
  MEETING           // Meeting
  PROPOSAL_SENT     // Proposta inviata
  STAGE_CHANGE      // Cambio stato
  VIDEO_SENT        // Video Tella inviato
  LETTER_SENT       // Lettera cartacea inviata
  LINKEDIN_SENT     // Connessione/InMail LinkedIn inviata
  RESPONSE_RECEIVED // Risposta ricevuta dal prospect
  VIDEO_VIEWED      // Il prospect ha visto il video
  QUALIFICATION     // Azione di qualificazione (Daniela)
  WHATSAPP_SENT     // Messaggio WhatsApp inviato
  EMAIL_OUTREACH    // Email outreach inviata dal CRM
  CHANNEL_CHANGED   // Cambio canale comunicazione (WA->Email o viceversa)
}

enum CallOutcome {
  ANSWERED        // Risposto
  NO_ANSWER       // Non risponde
  BUSY            // Occupato
  NOT_INTERESTED  // Non interessato
  CALLBACK        // Richiamare
  INTERESTED      // Interessato
}

enum SearchStatus {
  PENDING     // In attesa
  RUNNING     // In esecuzione
  COMPLETED   // Completata
  FAILED      // Fallita
}

enum ScheduledSearchStatus {
  QUEUED      // In coda, da eseguire
  RUNNING     // In esecuzione ora
  COMPLETED   // Eseguita con successo
  FAILED      // Fallita
}

enum CommercialTag {
  ADS_ATTIVE_CONTROLLO_ASSENTE    // Spendono ma non misurano - PRIORITA 1
  TRAFFICO_SENZA_DIREZIONE        // Traffico ma niente CTA - PRIORITA 2
  STRUTTURA_OK_NON_PRIORITIZZATA  // Funziona ma non ottimizzato - PRIORITA 3
  DA_APPROFONDIRE                 // Ha GTM/tracking ma non chiaro se fa ads - PRIORITA 3
  NON_TARGET                      // Non spendono in ads - SKIP
}

// Obiezioni comuni durante le chiamate
enum Objection {
  BUDGET              // "Non abbiamo budget"
  TIMING              // "Non e' il momento giusto"
  ALREADY_HAVE        // "Abbiamo gia qualcuno che ci segue"
  NOT_INTERESTED      // "Non ci interessa"
  NEED_TO_THINK       // "Devo pensarci"
  DECISION_MAKER      // "Devo parlare con..."
  BAD_EXPERIENCE      // "Abbiamo avuto brutte esperienze"
  NO_NEED             // "Non ne abbiamo bisogno"
  OTHER               // Altro (specificare in notes)
}

// Tipi di next step
enum NextStepType {
  SEND_VIDEO          // Preparare e inviare video
  SEND_LETTER         // Inviare lettera cartacea
  SEND_LINKEDIN       // Contattare su LinkedIn
  CALLBACK            // Richiamare
  SEND_INFO           // Inviare materiale
  MEETING             // Fissare meeting
  PROPOSAL            // Inviare proposta
  WAIT                // Aspettare (loro richiameranno)
  CLOSE               // Chiudere (vinto o perso)
