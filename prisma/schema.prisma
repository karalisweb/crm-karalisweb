}

// ==========================================
// SEARCH CONFIG - Configurazione ricerche
// ==========================================
model SearchCategory {
  id         String   @id @default(uuid())
  label      String   @unique
  icon       String   @default("🏢")
  order      Int      @default(0)
  active     Boolean  @default(true)
  cluster    String   @default("casa")      // "casa" | "microturismo"
  subcluster String   @default("altro")     // es. "arredo", "infissi", "edilizia_alto", etc.
  priority   Int      @default(50)          // 1 = massima priorità, 100 = minima
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("search_categories")
}

model SearchLocation {
  id          String   @id @default(uuid())
  name        String   @unique
  region      String   @default("")         // "Emilia-Romagna", "Veneto", etc.
  order       Int      @default(0)
  active      Boolean  @default(true)
  wave        Int      @default(1)
  isCapoluogo Boolean  @default(true) @map("is_capoluogo") // true = capoluogo provincia, false = città distretto
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("search_locations")
}

// ==========================================
// SCHEDULED SEARCH - Ricerche automatiche notturne
// ==========================================
model ScheduledSearch {
  id           String                @id @default(uuid())
  query        String                // es. "Infissi"
  location     String                // es. "Lecce"
  status       ScheduledSearchStatus @default(QUEUED)
  priority     Int                   @default(0) // Ordine esecuzione (0 = prima)

  // Tracking esecuzione
  lastRunAt    DateTime?             @map("last_run_at")
  searchId     String?               @map("search_id")
  errorMessage String?               @map("error_message")

  createdAt    DateTime              @default(now()) @map("created_at")
  updatedAt    DateTime              @updatedAt @map("updated_at")

  @@unique([query, location])
  @@map("scheduled_searches")
}

// ==========================================
// SETTINGS - Configurazioni app
// ==========================================
model Settings {
  id        String   @id @default("default")

  // Giorni dopo invio video: se non guardato, crea promemoria follow-up (default 7)
  followUpDaysVideo   Int    @default(7) @map("follow_up_days_video")

  // Mesi prima di ricontattare DA_RICHIAMARE_6M (default 6)
  recontactMonths     Int    @default(6) @map("recontact_months")

  // Ricerche Programmate
  scheduledSearchesPerRun  Int    @default(1)  @map("scheduled_searches_per_run")
  scheduledSearchHour      Int    @default(2)  @map("scheduled_search_hour")
  scheduledLeadsPerSearch  Int    @default(50) @map("scheduled_leads_per_search")

  // AI Configuration
  aiProvider               String   @default("gemini") @map("ai_provider") // gemini | claude | openai
  aiModelGemini            String?  @map("ai_model_gemini")   // es. gemini-2.5-flash
  aiModelClaude            String?  @map("ai_model_claude")   // es. claude-sonnet-4-6
  aiModelOpenai            String?  @map("ai_model_openai")   // es. gpt-4o

  // Prompt templates
  strategicAnalysisPrompt  String?  @map("strategic_analysis_prompt") @db.Text
  readingScriptPrompt      String?  @map("reading_script_prompt") @db.Text
  analystPrompt            String?  @map("analyst_prompt") @db.Text
  scriptwriterPrompt       String?  @map("scriptwriter_prompt") @db.Text
  emailGenPrompt           String?  @map("email_gen_prompt") @db.Text  // Istruzioni AI per scrivere la mail 1 (opt-in)
  optInSubjects            String?  @map("opt_in_subjects") @db.Text   // Lista oggetti mail opt-in (uno per riga, a rotazione)

  // ==========================================
  // EMAIL & MESSAGGI
  // ==========================================
  // Mittente
  emailFromAddress    String?  @map("email_from_address")    // default: env SMTP_FROM_OUTREACH
  emailFromName       String?  @map("email_from_name")       // default: env SMTP_FROM_NAME

  // Footer GDPR
  gdprCompanyName     String?  @map("gdpr_company_name")
  gdprAddress         String?  @map("gdpr_address")
  gdprVatNumber       String?  @map("gdpr_vat_number")       // P.IVA
  gdprFooterText      String?  @map("gdpr_footer_text")      @db.Text // "Hai ricevuto questa email..."
  gdprUnsubscribeText String?  @map("gdpr_unsubscribe_text") // "Non desidero ricevere..."

  // Firma usata nelle mail di outreach opt-in
  signatureAlessio      String?  @map("signature_alessio") @db.Text

  // Outreach opt-in (mail 1: invita a compilare il questionario / self-assessment)
  sdLandingUrl          String?  @map("sd_landing_url")          // Landing Metodo SD (es. karalisweb.net/web-marketing)
  alessioLinkedinUrl    String?  @map("alessio_linkedin_url")    // Profilo LinkedIn di Alessio (prova sociale)
  questionnaireUrl      String?  @map("questionnaire_url")       // Link self-assessment/questionario ({{QUESTIONARIO}}) — unico link della mail 1
  emailDailyCap         Int      @default(20) @map("email_daily_cap") // Quante aziende contattare via mail al giorno
  pausedSegments        String?  @map("paused_segments")          // Settori (segment key, separati da virgola) da NON contattare ora: esclusi da coda e mailer

  // Gate di approvazione: se true, la mail 1 NON parte in automatico → coda di approvazione (Alessio approva/ritocca)
  outreachRequireApproval Boolean @default(true) @map("outreach_require_approval")
  // Soglia score per entrare nella coda di approvazione (sotto = lasciati da parte)
  outreachApprovalMinScore Int    @default(60) @map("outreach_approval_min_score")

  // Notifiche
  // Email destinatarie delle notifiche video views (separate da virgola)
  // es. "alessio@karalisweb.net,consulenza@karalisweb.net"
  notificationEmails    String?  @map("notification_emails") @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}
