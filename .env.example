# ==========================================
# KW Sales CRM - Environment Variables Template
# ==========================================
# Copia questo file come .env e compila i valori
# cp .env.example .env

# ==========================================
# DATABASE
# ==========================================
# PostgreSQL - modifica con le tue credenziali
DATABASE_URL="postgresql://user:password@localhost:5432/sales_app"

# ==========================================
# NEXTAUTH
# ==========================================
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIA_QUESTO_VALORE"
NEXTAUTH_URL="http://localhost:3003"

# ==========================================
# APIFY
# ==========================================
# Ottieni da: https://console.apify.com/account/integrations
APIFY_TOKEN=""
APIFY_WEBHOOK_SECRET=""

# ==========================================
# CRON JOBS
# ==========================================
# Secret per autenticare le chiamate cron (usato anche per /api/internal/*)
# Genera con: openssl rand -hex 32
CRON_SECRET=""

# ==========================================
# GEMINI AI
# ==========================================
# Ottieni da: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ==========================================
# EMAIL SMTP
# ==========================================
# Configurazione per invio email OTP e reset password (dominio principale)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@example.com"

# --- Trasporto OUTREACH dedicato (dominio separato, NON il principale) ---
# Se valorizzato OUTREACH_SMTP_HOST, l'outreach commerciale parte da QUI (protegge
# la reputazione del dominio principale). Se vuoto, ricade sul trasporto principale.
# Mittente: Impostazioni → emailFromAddress.
OUTREACH_SMTP_HOST=""
OUTREACH_SMTP_PORT="587"
OUTREACH_SMTP_SECURE="false"
OUTREACH_SMTP_USER=""
OUTREACH_SMTP_PASSWORD=""

# Secret condiviso col Google Form (Apps Script) per il webhook questionario.
# Vedi docs/google-form-questionario.md
QUESTIONNAIRE_WEBHOOK_SECRET=""

# ==========================================
# WORKFLOW ENGINE (invio email automatico)
# ==========================================
# Tetto di invii REALI al giorno (anti-spam / reputazione dominio). 0 = stop invii.
WORKFLOW_DAILY_CAP="20"
# Invii max per singola esecuzione del cron (per distribuirli nella giornata).
WORKFLOW_PER_RUN_CAP="4"
