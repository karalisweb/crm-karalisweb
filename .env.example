# ==========================================
# KW Sales CRM - Environment Variables Template
# ==========================================
# Copia questo file come .env e compila i valori
# cp .env.example .env

# ==========================================
# DATABASE
# ==========================================
# PostgreSQL - modifica con le tue credenziali
DATABASE_URL="postgresql://user:password@localhost:5432/sales_app"

# ==========================================
# NEXTAUTH
# ==========================================
# Genera con: openssl rand -base64 32
NEXTAUTH_SECRET="CAMBIA_QUESTO_VALORE"
NEXTAUTH_URL="http://localhost:3003"

# ==========================================
# APIFY
# ==========================================
# Ottieni da: https://console.apify.com/account/integrations
APIFY_TOKEN=""
APIFY_WEBHOOK_SECRET=""

# ==========================================
# CRON JOBS
# ==========================================
# Secret per autenticare le chiamate cron (usato anche per /api/internal/*)
# Genera con: openssl rand -hex 32
CRON_SECRET=""

# ==========================================
# GEMINI AI
# ==========================================
# Ottieni da: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# ==========================================
# EMAIL SMTP
# ==========================================
# Configurazione per invio email OTP e reset password
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
SMTP_FROM="noreply@example.com"
